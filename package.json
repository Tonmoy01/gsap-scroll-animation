{
  "name": "react-scroll-motion-kit",
  "version": "1.0.0",
  "description": "A production-ready React animation library powered by GSAP ScrollTrigger — fade, slide, scale, parallax, stagger, and text reveal animations with a clean component API.",
  "author": "Tonmoy Khan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tonmoykhan/react-scroll-motion-kit"
  },
  "homepage": "https://github.com/tonmoykhan/react-scroll-motion-kit#readme",
  "bugs": {
    "url": "https://github.com/tonmoykhan/react-scroll-motion-kit/issues"
  },
  "keywords": [
    "react",
    "gsap",
    "scroll",
    "animation",
    "scroll-trigger",
    "parallax",
    "fade",
    "reveal",
    "motion",
    "typescript"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run type-check && npm run build",
    "release": "npm run prepublishOnly && npm publish --access public",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "gsap": ">=3.12.0",
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "gsap": "^3.12.5",
    "jsdom": "^24.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
